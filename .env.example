# LLM provider: groq | google | openai | ollama | local | mock
# LLM_PROVIDER is kept for compatibility with the older config style.
# LLM_BACKEND also works and takes the same values.
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-1.5-flash

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama / local OpenAI-compatible endpoint
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=llama3.1:8b

# Dataset paths.
# The app falls back to root CSV files if these paths do not exist.
PRICING_CSV_PATH=provider_pricing_curated.csv
DEPLOY_API_CSV_PATH=provider_deploy_api.csv

# Retrieval/generation tuning.
RAG1_TOP_K=5
RAG2_TOP_K=2
MAX_TOKENS=2048
TEMPERATURE=0.3
