# Pilihan backend: "groq", "google", atau "local"
LLM_BACKEND=groq

# === Groq Configurations ===
# Pilih model Groq: "llama-3.1-8b-instant", "qwen/qwen3-32b", atau "mixtral-8x7b-32768"
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# === Google Gemini Configurations ===
# Pilih model Google: "gemini-1.5-flash", "gemini-1.5-pro", dsb.
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-1.5-flash

# === Local Ollama Configurations ===
# Contoh: http://localhost:11434/v1
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=llama3.1:8b