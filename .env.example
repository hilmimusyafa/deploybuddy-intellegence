# ──────────────────────────────────────────────────────────────────
# DeployBuddy RAG — Environment Configuration
# Copy file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN commit .env ke version control (tambahkan ke .gitignore).
# ──────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────
# Pilih: ollama | openai | anthropic | groq
LLM_PROVIDER=ollama

# ── Ollama (local) ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic (Claude) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Groq (free tier, cepat) ──────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Dataset CSV Paths (detachable) ───────────────────────────────
# Ganti path sesuai lokasi file CSV kamu
PRICING_CSV_PATH=data/provider_pricing_curated.csv
DEPLOY_API_CSV_PATH=data/provider_deploy_api.csv

# ── RAG Settings ─────────────────────────────────────────────────
RAG1_TOP_K=12      # berapa baris pricing yang di-retrieve per query
RAG2_TOP_K=3       # berapa provider deploy API yang di-retrieve

# ── LLM Generation ───────────────────────────────────────────────
MAX_TOKENS=4096
TEMPERATURE=0.3
